SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql+asyncpg://baay:baay_secret@localhost:5432/baay_reseau
REDIS_URL=redis://localhost:6379

# WhatsApp Business API
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=baay-reseau-verify

# Wave API
WAVE_API_KEY=your-wave-api-key

# Orange Money API
ORANGE_MONEY_API_KEY=your-orange-money-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Cloudinary (for product image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (subscription billing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Sentry (error monitoring)
SENTRY_DSN=https://your-sentry-dsn

# Africa's Talking (SMS receipts)
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=your-africastalking-username
AT_SENDER_ID=BAAY

# Google OAuth (login with Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Firebase Cloud Messaging (push notifications)
# Use FCM v1 API: generate OAuth2 access token from service account
FCM_SERVER_KEY=your-fcm-oauth-access-token
FCM_PROJECT_ID=your-fcm-project-id

# VAPID Key (push notifications frontend)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
